# ============================================================
# FICHIER À COMPLÉTER POUR CHAQUE NOUVELLE DÉMO / NOUVEAU CLIENT
# Copier : cp terraform.tfvars.example terraform.tfvars
# NE JAMAIS commiter terraform.tfvars (déjà dans .gitignore)
# ============================================================

# Souscription Azure du client (az account list pour trouver l'ID)
subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Note : distribution_id et dockerPullSecret viennent du fichier Cortex .values.yaml
# Ils sont passés directement au bootstrap : make up CORTEX_YAML=./client.values.yaml

# Optionnel — modifier si besoin pour ce client
# location             = "francecentral"
# resource_group_name  = "rg-cortex-demo"
# vm_size              = "Standard_D2s_v3"
